{{!
    @template mod_crucible/extend

    Instructor-only panel for extending the active event duration.

    Example context (json):
    {
        "eventid": "abc-123",
        "cmid": 1,
        "extendlabel": "Extend Event",
        "durationlabel": "Duration (minutes)",
        "sesskey": "xyz"
    }
}}

<div class="extend-panel card mt-3 mb-3">
    <div class="card-body">
        <h5 class="card-title">{{extendlabel}}{{#activityname}} — {{activityname}}{{/activityname}}</h5>
        <div class="form-inline">
            <label for="extend-duration-{{eventid}}" class="mr-2">{{durationlabel}}</label>
            <input type="number" id="extend-duration-{{eventid}}" class="form-control mr-2" value="1" min="0.5" max="168" step="0.5" style="width: 100px;">
            <button class="btn btn-primary extend-event-btn" data-eventid="{{eventid}}" data-cmid="{{cmid}}" data-sesskey="{{sesskey}}">{{extendlabel}}</button>
        </div>
    </div>
</div>
