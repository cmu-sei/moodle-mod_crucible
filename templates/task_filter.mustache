{{!
    @template mod_crucible/task_filter

    This template renders the task filter buttons and count information

    Example context (json):
    {
        "title": "Filter Tasks",
        "cmid": 123,
        "allurl": "?id=123&filter=all",
        "executableurl": "?id=123&filter=executable",
        "nonexecutableurl": "?id=123&filter=nonexecutable",
        "allactive": true,
        "executableactive": false,
        "nonexecutableactive": false,
        "showall": "Show All",
        "userexecutableonly": "User Executable Only",
        "nonexecutableonly": "Non-Executable Only",
        "showfilterinfo": true,
        "totaltasks": 10,
        "filteredcount": 5
    }
}}

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">{{title}}</h5>
    </div>
    <div class="card-body">
        <div class="btn-group mb-2" role="group" aria-label="Task filter">
            <a href="{{allurl}}" class="btn btn-sm {{#allactive}}btn-primary{{/allactive}}{{^allactive}}btn-outline-secondary{{/allactive}}">
                {{showall}}
            </a>
            <a href="{{executableurl}}" class="btn btn-sm {{#executableactive}}btn-primary{{/executableactive}}{{^executableactive}}btn-outline-secondary{{/executableactive}}">
                {{userexecutableonly}}
            </a>
            <a href="{{nonexecutableurl}}" class="btn btn-sm {{#nonexecutableactive}}btn-primary{{/nonexecutableactive}}{{^nonexecutableactive}}btn-outline-secondary{{/nonexecutableactive}}">
                {{nonexecutableonly}}
            </a>
        </div>
        {{#showfilterinfo}}
            <div class="alert alert-info mb-0 mt-2 p-2">
                Showing <strong>{{filteredcount}}</strong> of <strong>{{totaltasks}}</strong> tasks
            </div>
        {{/showfilterinfo}}
        {{^showfilterinfo}}
            <div class="mt-1"><small class="text-muted">Total tasks: {{totaltasks}}</small></div>
        {{/showfilterinfo}}
    </div>
</div>
